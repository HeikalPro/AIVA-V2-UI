# Optional: point API at backend directly (omit to use Vite proxy in dev)
# VITE_API_BASE_URL=http://localhost:8000

# Standard auth (SMTP sign-up / login) is always on.
# Set to 1 to show "Sign in with Zoho" again (backend Zoho routes must also be configured).
# VITE_ENABLE_ZOHO_LOGIN=0

# Login: username + provider dropdown (Gmail, Yahoo, Hotmail, …). Set 0 for full email field.
# VITE_LOGIN_EMAIL_PICKER=1
